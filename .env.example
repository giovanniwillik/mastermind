# ===========================================================
# MASTERMIND - VARIÁVEIS DE AMBIENTE (.env.example)
# ===========================================================
# Copie este arquivo para .env e configure as variáveis
# para seu ambiente específico
# ===========================================================

# ==================== DATABASE ====================
# Configurações do PostgreSQL 15

# URL de conexão do banco de dados
# Formato: jdbc:postgresql://host:port/database
# Docker: use 'db' como hostname
# Local: use 'localhost'
DB_URL=jdbc:postgresql://db:5432/mastermind

# Usuário do PostgreSQL
# Padrão: postgres
# Em produção: use um usuário específico menos privilegiado
DB_USERNAME=postgres

# Senha do PostgreSQL
# IMPORTANTE: Mude para uma senha forte em produção!
# Exemplo forte: $(openssl rand -base64 32)
DB_PASSWORD=postgres

# ==================== SERVER ====================
# Configurações do Spring Boot

# Porta do servidor (padrão: 8080)
# Em Docker: manter 8080
# Em produção: geralmente 8080 (proxy reverso na frente)
SERVER_PORT=8080

# ==================== JWT / SECURITY ====================
# Configurações de autenticação e autorização JWT

# Chave secreta para assinar tokens JWT
# CRITICAMENTE IMPORTANTE em produção!
# Requisitos:
# - Mínimo 32 caracteres
# - Caracteres aleatórios (não senha fraca)
# 
# Para gerar uma chave segura:
#   Linux/macOS:  openssl rand -base64 32
#   PowerShell:   [System.Convert]::ToBase64String([System.Random]::new())
#   Online:       https://tools.ietf.org/html/rfc4648
#
# Nunca comite o valor real em repositórios públicos!
JWT_SECRET=your-super-secure-secret-key-minimum-32-characters-random

# Tempo de expiração do token JWT em milissegundos
# Padrão: 86400000 (24 horas)
# Valores comuns:
#   1 hora   = 3600000
#   24 horas = 86400000
#   7 dias   = 604800000
# Em produção: considere 12-24 horas para segurança
JWT_EXPIRATION=86400000

# ==================== DATABASE INITIALIZATION ====================
# Esquema e inicialização

# Arquivo SQL para inicializar o banco (não altere em produção)
# schema.sql é executado automaticamente na primeira execução
# Contém: CREATE TABLE, CREATE INDEX

# ==================== FRONTEND (Docker Only) ====================
# Configurações específicas para containerização

# URL do backend no contexto do frontend (dentro do container)
# Docker: http://backend:8080
# Local: http://localhost:8080
BACKEND_URL=http://backend:8080

# ==================== FRONTEND (Development/Production) ====================
# Se rodar frontend localmente (npm start)

# API URL para desenvolvimento local
# É normalmente configurado em frontend/src/environments/environment.development.ts
# Mas pode ser sobrescrito via variável de ambiente
FRONTEND_API_URL=http://localhost:8080/api

# ==================== NGINX (Docker Only) ====================
# Configurações do servidor web (somente em Docker)

# Não precisa alterar - nginx.conf é gerado no build
# Port: 80 (HTTP) - altere em docker-compose.yml se necessário

# ==================== LOGGING ====================
# Configurações de logging (Spring Boot)

# Nível de log (TRACE, DEBUG, INFO, WARN, ERROR)
# Desenvolvimento: DEBUG (mais detalhes)
# Produção: INFO (menos logs para performance)
# Troubleshooting: DEBUG ou TRACE
LOGGING_LEVEL=INFO

# ==================== CORS ====================
# Configurações de CORS (Cross-Origin Resource Sharing)

# URLs de origem permitidas (separadas por vírgula)
# Padrão Docker: http://localhost (frontend)
# Padrão Local: http://localhost:4200 (ng serve)
# Produção: seu domínio principal
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:4200

# ==================== ENVIRONMENT ====================
# Identification do ambiente

# Ambiente: development, staging, production
ENVIRONMENT=development

# ==================== HEALTH CHECK ====================
# Configurações para health checks Docker

# Comando de health check (não altere)
# Verifica se o PostgreSQL está disponível
HEALTHCHECK_CMD=pg_isready -U postgres -d mastermind

# ==================== PRODUCTION CHECKLIST ====================
# ANTES DE FAZER DEPLOY PARA PRODUÇÃO
# 
# [ ] Mudar JWT_SECRET para um valor aleatório seguro (32+ chars)
# [ ] Mudar DB_PASSWORD para senha forte (complexa e longa)
# [ ] Mudar DB_URL para servidor PostgreSQL de produção
# [ ] Mudar CORS_ALLOWED_ORIGINS para seus domínios reais
# [ ] Ativar HTTPS (certificado SSL/TLS)
# [ ] Configurar backup automático do banco de dados
# [ ] Configurar alertas e monitoramento
# [ ] Testar fluxo completo em staging antes de produção
# [ ] Revisar logs de erro e performance
# [ ] Implementar rate limiting e proteção contra brute force
# [ ] Configurar WAF (Web Application Firewall)
# [ ] Documentar credenciais em sistema seguro (não em .env público)

# ==================== EXEMPLOS DE VALORES PARA PRODUÇÃO ====================
# NÃO COPIE ESTES VALORES - GERE NOVOS!
# 
# Exemplo de DB_PASSWORD forte:
# DB_PASSWORD=Xk9p$mL2@qR8vD4wT6zJ1nC3bF5hX7
#
# Exemplo de JWT_SECRET:
# JWT_SECRET=9K2pL6mN8xQ3rT5uV7wY0zZ2aB4cD6eF
#
# Exemplo de CORS para produção:
# CORS_ALLOWED_ORIGINS=https://mastermind.com,https://www.mastermind.com,https://api.mastermind.com
# DB_PORT=5432
